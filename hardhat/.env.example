# ─────────────────────────────────────────────────────────────────────────────
# ArbitCore — Hardhat Environment Variables
#
# INSTRUCTIONS:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in your real values below
#   3. NEVER commit .env to git (it is already in .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# Your deployer wallet private key (WITHOUT 0x prefix)
PRIVATE_KEY=your_private_key_here

# RPC endpoint for HashKey Chain
# Mainnet : https://mainnet.hsk.xyz
# Testnet : https://hashkeychain-testnet.alt.technology
RPC_URL=https://hashkeychain-testnet.alt.technology

# (Optional) Wallet address used as AI Oracle
# Defaults to the deployer if left blank
AI_ORACLE=
