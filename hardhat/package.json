{
  "name": "arbiter-hardhat",
  "version": "1.0.0",
  "description": "Hardhat workspace for ArbitCore smart contract",
  "private": true,
  "scripts": {
    "compile":  "hardhat compile",
    "deploy":   "hardhat run scripts/deploy.js --network hashkey",
